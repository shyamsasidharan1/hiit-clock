# Admin access token — anyone with the URL ?admin=<token> can upload .txt files.
VITE_ADMIN_TOKEN=change-me-to-something-secret

# AWS S3 storage
VITE_S3_BUCKET=shyam-sasidharan-gmail-com-hiit-workouts-store
VITE_AWS_REGION=us-east-1
VITE_AWS_ACCESS_KEY_ID=your-access-key-id
VITE_AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Max number of workout files allowed in the S3 bucket
VITE_MAX_WORKOUTS=50
