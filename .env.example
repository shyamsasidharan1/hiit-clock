# Admin access token — anyone with ?admin=<token> in the URL can upload .txt files.
VITE_ADMIN_TOKEN=change-me-to-something-secret

# Lambda function URL (handles all S3 and AI operations)
VITE_API_URL=https://your-lambda-url.lambda-url.us-east-1.on.aws

# S3 bucket name (still needed for reference)
VITE_S3_BUCKET=shyam-sasidharan-gmail-com-hiit-workouts-store
VITE_AWS_REGION=us-east-1

# Max number of workout files allowed in the S3 bucket (enforced server-side in Lambda)
VITE_MAX_WORKOUTS=50
